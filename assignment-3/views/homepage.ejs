<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopPK — Pakistan's Best Online Store</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- TOP BAR: small announcement bar above the navbar with delivery info and contact -->
    <div class="top-bar">
        <div class="top-bar-inner">
            <span class="top-bar-left">&#128666; Free delivery on orders above Rs. 2000</span>
            <span class="top-bar-right">
                <span>&#128222; 0311-1234567</span>
                <span>&#9993; support@shoppk.com</span>
            </span>
        </div>
    </div>

    <!-- NAVBAR: top navigation bar with logo, search and cart -->
    <nav class="navbar">
        <div class="navbar-inner">

            <!-- Logo -->
            <div class="navbar-logo">
                <a href="#">Shop<span class="logo-accent">PK</span></a>
            </div>

            <!-- Search bar -->
            <div class="navbar-search">
                <input type="text" class="search-input" placeholder="Search for products, brands and more...">
                <button class="search-btn">&#128269;</button>
            </div>

            <!-- Cart and login -->
            <div class="navbar-actions">
                <a href="#" class="cart-icon">
                    &#128722;
                    <span class="cart-badge">3</span>
                </a>
                <a href="#" class="login-btn">Login / Sign Up</a>
                <button id="hamburger-btn" class="hamburger-btn" aria-label="Open navigation menu">
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                </button>
            </div>

        </div>

        <!-- Navigation links below the main navbar row -->
        <div class="nav-links" id="nav-menu">
            <a href="#">Home</a>
            <a href="#">Men</a>
            <a href="#">Women</a>
            <a href="#">Electronics</a>
            <a href="#">Shoes</a>
            <a href="#">Bags</a>
            <a href="#" class="nav-sale">&#128293; Sale</a>
        </div>
    </nav>

    <!-- HERO: large banner section that user sees first when page opens -->
    <section class="hero">
        <div class="hero-content">
            <p class="hero-tag">&#127881; New Season Arrivals</p>
            <h1 class="hero-heading">Pakistan's Best<br>Online Store</h1>
            <p class="hero-subtext">Shop thousands of products from top brands — delivered fast to your doorstep anywhere in Pakistan.</p>
            <a href="#" class="hero-btn">Shop Now &#8594;</a>
        </div>
    </section>

    <!-- CATEGORIES: row of clickable category cards -->
    <section class="categories">
        <div class="section-container">
            <h2 class="section-title">Shop by Category</h2>

            <div class="category-grid">

                <div class="category-card">
                    <div class="category-icon">&#128084;</div>
                    <span class="category-name">Men</span>
                </div>

                <div class="category-card">
                    <div class="category-icon">&#128131;</div>
                    <span class="category-name">Women</span>
                </div>

                <div class="category-card">
                    <div class="category-icon">&#128241;</div>
                    <span class="category-name">Electronics</span>
                </div>

                <div class="category-card">
                    <div class="category-icon">&#128094;</div>
                    <span class="category-name">Shoes</span>
                </div>

                <div class="category-card">
                    <div class="category-icon">&#128092;</div>
                    <span class="category-name">Bags</span>
                </div>

                <div class="category-card category-sale">
                    <div class="category-icon">&#127991;</div>
                    <span class="category-name">Sale</span>
                </div>

            </div>
        </div>
    </section>

    <!-- PRODUCTS: grid of featured product cards -->
    <section class="products">
        <div class="section-container">
            <h2 class="section-title">Featured Products</h2>

            <div class="product-grid">

                <!-- Product Card 1 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/e8f0fe/1a237e?text=Men+Shirt" alt="Men's Casual Shirt" class="product-image">
                        <span class="product-badge">New</span>
                    </div>
                    <div class="product-info">
                        <p class="product-name">Men's Casual Cotton Shirt</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9734; <span class="review-count">(128)</span></div>
                        <p class="product-price">Rs. 1,850</p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 2 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/fce4ec/880e4f?text=Women+Dress" alt="Women's Floral Dress" class="product-image">
                        <span class="product-badge badge-sale">-30%</span>
                    </div>
                    <div class="product-info">
                        <p class="product-name">Women's Floral Summer Dress</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span class="review-count">(204)</span></div>
                        <p class="product-price">Rs. 2,499 <span class="price-old">Rs. 3,500</span></p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 3 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/e8f5e9/1b5e20?text=Earbuds" alt="Wireless Earbuds" class="product-image">
                    </div>
                    <div class="product-info">
                        <p class="product-name">Wireless Bluetooth Earbuds Pro</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9734; <span class="review-count">(87)</span></div>
                        <p class="product-price">Rs. 3,200</p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 4 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/fff3e0/e65100?text=Sneakers" alt="Men's Sneakers" class="product-image">
                        <span class="product-badge badge-sale">-20%</span>
                    </div>
                    <div class="product-info">
                        <p class="product-name">Men's Sport Running Sneakers</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span class="review-count">(312)</span></div>
                        <p class="product-price">Rs. 4,750 <span class="price-old">Rs. 5,999</span></p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 5 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/f3e5f5/4a148c?text=Handbag" alt="Women's Handbag" class="product-image">
                        <span class="product-badge">Hot</span>
                    </div>
                    <div class="product-info">
                        <p class="product-name">Women's Designer Handbag</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9734; <span class="review-count">(156)</span></div>
                        <p class="product-price">Rs. 5,500</p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 6 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/e0f7fa/006064?text=Smartwatch" alt="Smartwatch" class="product-image">
                    </div>
                    <div class="product-info">
                        <p class="product-name">Smart Fitness Watch Band</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span class="review-count">(241)</span></div>
                        <p class="product-price">Rs. 6,999</p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 7 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/fff8e1/f57f17?text=Lawn+Suit" alt="Lawn Suit" class="product-image">
                        <span class="product-badge badge-sale">-40%</span>
                    </div>
                    <div class="product-info">
                        <p class="product-name">Women's Printed Lawn 3-Piece Suit</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span class="review-count">(399)</span></div>
                        <p class="product-price">Rs. 2,100 <span class="price-old">Rs. 3,500</span></p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

                <!-- Product Card 8 -->
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="https://placehold.co/280x220/e8eaf6/1a237e?text=Backpack" alt="Travel Backpack" class="product-image">
                    </div>
                    <div class="product-info">
                        <p class="product-name">Waterproof Travel Backpack 30L</p>
                        <div class="product-stars">&#9733;&#9733;&#9733;&#9733;&#9734; <span class="review-count">(73)</span></div>
                        <p class="product-price">Rs. 3,800</p>
                        <button class="add-to-cart-btn">Add to Cart</button>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- PROMO BANNER: wide sale promotional banner in the middle of the page -->
    <section class="promo-banner">
        <div class="promo-inner">
            <p class="promo-tag">Limited Time Offer</p>
            <h2 class="promo-heading">Sale Up To 70% Off</h2>
            <p class="promo-subtext">Grab the best deals before they're gone — shop thousands of discounted items today!</p>
            <a href="#" class="promo-btn">Explore Deals &#8594;</a>
        </div>
    </section>

    <!-- NEWSLETTER: email subscription section -->
    <section class="newsletter">
        <div class="section-container">
            <h2 class="newsletter-heading">Stay in the Loop</h2>
            <p class="newsletter-subtext">Subscribe to get exclusive deals, new arrivals, and special offers straight to your inbox.</p>
            <form class="newsletter-form">
                <input type="email" class="newsletter-input" placeholder="Enter your email address...">
                <button type="submit" class="newsletter-btn">Subscribe</button>
            </form>
        </div>
    </section>

    <!-- FOOTER: bottom section with links and info -->
    <footer class="footer">
        <div class="footer-inner">

            <!-- Column 1: About -->
            <div class="footer-col">
                <h3 class="footer-logo">Shop<span class="logo-accent">PK</span></h3>
                <p class="footer-about">Pakistan's trusted online marketplace. We bring you thousands of products from top local and international brands, delivered fast across Pakistan.</p>
                <div class="social-links">
                    <a href="#" class="social-link">f</a>
                    <a href="#" class="social-link">in</a>
                    <a href="#" class="social-link">tw</a>
                    <a href="#" class="social-link">yt</a>
                </div>
            </div>

            <!-- Column 2: Quick Links -->
            <div class="footer-col">
                <h4 class="footer-col-heading">Quick Links</h4>
                <ul class="footer-links">
                    <li><a href="#">Home</a></li>
                    <li><a href="#">Men's Fashion</a></li>
                    <li><a href="#">Women's Fashion</a></li>
                    <li><a href="#">Electronics</a></li>
                    <li><a href="#">Shoes & Footwear</a></li>
                    <li><a href="#">Bags & Accessories</a></li>
                    <li><a href="#">Sale Items</a></li>
                </ul>
            </div>

            <!-- Column 3: Customer Service -->
            <div class="footer-col">
                <h4 class="footer-col-heading">Customer Service</h4>
                <ul class="footer-links">
                    <li><a href="#">My Account</a></li>
                    <li><a href="#">Track My Order</a></li>
                    <li><a href="#">Return & Exchange</a></li>
                    <li><a href="#">Shipping Policy</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms & Conditions</a></li>
                    <li><a href="#">FAQs</a></li>
                </ul>
            </div>

            <!-- Column 4: Contact Info -->
            <div class="footer-col">
                <h4 class="footer-col-heading">Contact Info</h4>
                <ul class="footer-contact">
                    <li>&#128205; Office 42, Blue Area, Islamabad, Pakistan</li>
                    <li>&#128222; 0311-1234567</li>
                    <li>&#128222; 0321-7654321</li>
                    <li>&#9993; support@shoppk.com</li>
                    <li>&#9989; Mon–Sat: 9:00 AM – 8:00 PM</li>
                </ul>
            </div>

        </div>

        <!-- Copyright bar -->
        <div class="footer-copyright">
            <p>&copy; 2024 ShopPK. All Rights Reserved. Made with &#10084; in Pakistan.</p>
        </div>
    </footer>

    <script src="/js/navbar.js"></script>

</body>
</html>
